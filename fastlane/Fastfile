default_platform(:ios)

platform :ios do
  desc "Build and push to TestFlight"
  lane :beta do
    # ── Keychain + certificate ─────────────────────────────────────
    keychain_name = "build.keychain"
    keychain_password = ""

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    cert_path = "/tmp/distribution.p12"
    File.write(cert_path, Base64.decode64(ENV["DIST_CERT_BASE64"]))

    import_certificate(
      certificate_path: cert_path,
      certificate_password: ENV["DIST_CERT_PASSWORD"],
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )

    # ── App Store Connect API key ──────────────────────────────────
    api_key = app_store_connect_api_key(
      key_id:        "3DRJXFL3AZ",
      issuer_id:     "68f79706-7f0b-490d-a0f1-4601bbe95e87",
      key_content:   ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: false,
      in_house: false
    )

    # ── Generate Xcode project ─────────────────────────────────────
    sh "cd .. && xcodegen generate"

    # ── Write ASC key to disk so xcodebuild can use it for auto-signing ──
    asc_key_path = "/tmp/asc_key.p8"
    File.write(asc_key_path, ENV["ASC_PRIVATE_KEY"])

    # ── Download provisioning profiles ────────────────────────────
    # Explicitly fetch all three profiles before gym so xcodebuild
    # doesn't fail with "Build input file cannot be found" on a fresh runner.
    ["com.nobsdash.nobs", "com.nobsdash.nobs.widget", "com.nobsdash.nobs.control"].each do |bid|
      get_provisioning_profile(
        api_key:        api_key,
        app_identifier: bid,
        adhoc:          false,
        skip_install:   false
      )
    end

    # ── Build ──────────────────────────────────────────────────────
    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj: "NOBS.xcodeproj"
    )

    gym(
      scheme:             "NOBS",
      project:            "NOBS.xcodeproj",
      configuration:      "Release",
      export_method:      "app-store",
      xcargs:             "-allowProvisioningUpdates -authenticationKeyPath #{asc_key_path} -authenticationKeyID 3DRJXFL3AZ -authenticationKeyIssuerID 68f79706-7f0b-490d-a0f1-4601bbe95e87",
      export_options: {
        signingStyle:               "automatic",
        teamID:                     "K853LKQLAS",
        uploadBitcode:              false,
        uploadSymbols:              true,
        compileBitcode:             false
      },
      output_directory:   "/tmp/gym_output",
      output_name:        "NOBS.ipa",
      clean:              true,
      silent:             false
    )

    # ── Upload to TestFlight ───────────────────────────────────────
    upload_to_testflight(
      api_key:                           api_key,
      app_identifier:                    "com.nobsdash.nobs",
      ipa:                               "/tmp/gym_output/NOBS.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission:                   true,
      distribute_external:               false,
      notify_external_testers:           false,
      changelog:                         "Latest build from main branch"
    )

    UI.success "✅ Build uploaded to TestFlight!"
  end

  desc "Build and submit to App Store"
  lane :release do
    # ── Keychain + certificate ─────────────────────────────────────
    keychain_name = "build.keychain"
    keychain_password = ""

    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    cert_path = "/tmp/distribution.p12"
    File.write(cert_path, Base64.decode64(ENV["DIST_CERT_BASE64"]))

    import_certificate(
      certificate_path: cert_path,
      certificate_password: ENV["DIST_CERT_PASSWORD"],
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )

    # ── App Store Connect API key ──────────────────────────────────
    api_key = app_store_connect_api_key(
      key_id:        "3DRJXFL3AZ",
      issuer_id:     "68f79706-7f0b-490d-a0f1-4601bbe95e87",
      key_content:   ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: false,
      in_house: false
    )

    # ── Generate Xcode project ─────────────────────────────────────
    sh "cd .. && xcodegen generate"

    # ── Write ASC key to disk so xcodebuild can use it for auto-signing ──
    asc_key_path = "/tmp/asc_key.p8"
    File.write(asc_key_path, ENV["ASC_PRIVATE_KEY"])

    # ── Build ──────────────────────────────────────────────────────
    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj: "NOBS.xcodeproj"
    )

    gym(
      scheme:             "NOBS",
      project:            "NOBS.xcodeproj",
      configuration:      "Release",
      export_method:      "app-store",
      xcargs:             "-allowProvisioningUpdates -authenticationKeyPath #{asc_key_path} -authenticationKeyID 3DRJXFL3AZ -authenticationKeyIssuerID 68f79706-7f0b-490d-a0f1-4601bbe95e87",
      export_options: {
        signingStyle:               "automatic",
        teamID:                     "K853LKQLAS",
        uploadBitcode:              false,
        uploadSymbols:              true,
        compileBitcode:             false
      },
      output_directory:   "/tmp/gym_output",
      output_name:        "NOBS.ipa",
      clean:              true,
      silent:             false
    )

    # ── Upload to App Store ────────────────────────────────────────
    upload_to_app_store(
      api_key:                           api_key,
      app_identifier:                    "com.nobsdash.nobs",
      ipa:                               "/tmp/gym_output/NOBS.ipa",
      skip_waiting_for_build_processing: true,
      submit_for_review:                 true,
      automatic_release:                 true
    )

    UI.success "✅ Build submitted to App Store for review!"
  end
end
